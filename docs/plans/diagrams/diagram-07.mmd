classDiagram
    class Node {
        +u128 id
        +&str label
        +u8 version
        +Option~ImmutablePropertiesMap~ properties
    }

    class Edge {
        +u128 id
        +&str label
        +u128 from
        +u128 to
        +u8 version
        +Option~ImmutablePropertiesMap~ properties
    }

    class Vector {
        +u128 id
        +&str label
        +Vec~f32~ data
        +Option~ImmutablePropertiesMap~ properties
    }

    class ImmutablePropertiesMap {
        +IndexMap~String, Value~ entries
        +get(key) Value
        +iter() Iterator
    }

    class Value {
        <<enum>>
        String(String)
        I32(i32)
        U32(u32)
        F32(f32)
        Bool(bool)
        Null
    }

    Node --> ImmutablePropertiesMap
    Edge --> ImmutablePropertiesMap
    Vector --> ImmutablePropertiesMap
    ImmutablePropertiesMap --> Value

    Edge --> Node : from
    Edge --> Node : to
