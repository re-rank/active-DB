graph LR
    subgraph CPU["CPU 코어"]
        C0["Core 0"]
        C1["Core 1"]
        C2["Core 2"]
        C3["Core 3"]
        C4["Core 4"]
        C5["Core 5"]
    end

    subgraph Assignment["워커 할당"]
        W0["Reader 0"] --> C0
        W1["Reader 1"] --> C1
        W2["Reader 2"] --> C2
        W3["Reader 3"] --> C3
        WR["Writer"] --> C4
        TK["Tokio Runtime"] --> C5
    end

    classDef reader fill:#c8e6c9,stroke:#2e7d32
    classDef writer fill:#ffcdd2,stroke:#c62828
    classDef runtime fill:#e3f2fd,stroke:#1565c0

    class W0,W1,W2,W3 reader
    class WR writer
    class TK runtime
